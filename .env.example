# ---- Ecomap environment ----
# AI research is OPTIONAL. Without a key, Ecomap runs fully offline using its
# deterministic research-methodology engine + the hand-authored benchmark case.

# DeepSeek API key (server-side only — never commit the real key).
# Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# ---- Real web + academic search (recommended for live, sourced data) ----
# Tavily: live web / news / government / policy search. https://tavily.com
TAVILY_API_KEY=tvly-...
# Semantic Scholar: academic papers. Works without a key at low volume; a key
# raises rate limits. https://www.semanticscholar.org/product/api
# SEMANTIC_SCHOLAR_API_KEY=...

# Optional overrides:
# DEEPSEEK_MODEL=deepseek-chat       # or deepseek-reasoner
# DEEPSEEK_BASE_URL=https://api.deepseek.com
